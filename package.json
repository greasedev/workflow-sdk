{
  "name": "@greaseclaw/workflow-sdk",
  "version": "0.0.1",
  "description": "Browser automation SDK for GreaseClaw workflows - navigate, interact, extract data with natural language",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/greasedev/workflow-sdk.git"
  },
  "keywords": [
    "browser-automation",
    "web-scraping",
    "ai-agent",
    "natural-language",
    "sdk",
    "workflow"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.1"
  },
  "peerDependencies": {
    "zod": "^3.x"
  },
  "devDependencies": {
    "@extension/tsconfig": "workspace:*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}